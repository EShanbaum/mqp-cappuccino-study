                "width": "800px",
                "position": "sticky",
                "top": "80px"
            },
            "response": [
                {
                    "id": "mic-user-study/b0-obscured-age",
                    "prompt": "What generation is the creator of the chart most likely from?",
                    "location": "sidebar",
                    "type": "dropdown",
                    "options": [
                        "Boomer",
                        "Gen-X",
                        "Millenial",
                        "Gen-Z"
